rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Aturan untuk profil pengguna
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Aturan untuk Sekolah (Settings)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan untuk berita, fasilitas, galeri
    match /news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /facilities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /gallery/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan whitelist admin
    match /admins/{email} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan fallback global (Admin dapat mengelola semua selama didefinisikan di atas)
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}