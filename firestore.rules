rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu
    function isSignedIn() {
      return request.auth != null;
    }

    // Mengizinkan user untuk mengelola profil mereka sendiri
    // Penting untuk inisialisasi awal profil setelah login
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Aturan untuk Sekolah (Tenant)
    match /schools/{schoolId} {
      allow read: if true;
      // Admin dapat mengedit data sekolah jika mereka terautentikasi
      // Dalam mode pengembangan ini kita permudah untuk inisialisasi
      allow write: if isSignedIn();
    }

    // Aturan global untuk koleksi konten lainnya
    match /{collectionName}/{docId} {
      allow read: if true;
      // Mengizinkan tulis jika user login (filter schoolId dilakukan di level aplikasi)
      allow write: if isSignedIn();
    }
  }
}