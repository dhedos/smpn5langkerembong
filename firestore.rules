rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu dasar
    function isSignedIn() {
      return request.auth != null;
    }

    // Mengizinkan pengguna mengelola profil mereka sendiri
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Mengizinkan admin yang login untuk mengelola data sekolah
    // Dalam tahap pengembangan, kita izinkan akses penuh bagi user yang login
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rule umum untuk koleksi lainnya agar tidak Missing Permissions saat init
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}