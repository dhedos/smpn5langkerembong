rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu
    function isSignedIn() {
      return request.auth != null;
    }

    // Aturan untuk profil pengguna (Users)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Aturan untuk Schools (Settings)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan untuk konten multi-tenant (news, facilities, gallery, dll)
    // Dalam mode pengembangan, izinkan tulis bagi yang sudah login
    // Produksi nanti bisa ditambahkan filter: request.resource.data.schoolId == userProfile.schoolId
    match /news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /facilities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /gallery/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /teachers/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan fallback
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
