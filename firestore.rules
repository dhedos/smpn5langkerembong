rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu untuk mengecek status login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi untuk mendapatkan data user
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Aturan untuk profil User
    match /users/{userId} {
      // User bisa baca dan tulis profilnya sendiri
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Aturan untuk Koleksi Sekolah (Tenant)
    match /schools/{schoolId} {
      // Publik bisa baca informasi sekolah
      allow read: if true;
      // Hanya admin sekolah tersebut atau superadmin yang bisa edit
      allow write: if isSignedIn() && (
        getUserData().role == 'superadmin' || 
        getUserData().schoolId == schoolId
      );
    }

    // Aturan untuk konten (News, Gallery, dll)
    // Menggunakan wildcard {collectionName} agar mencakup semua koleksi konten
    match /{collectionName}/{docId} {
      // Publik bisa baca semua konten yang diterbitkan
      allow read: if true;
      
      // Admin hanya bisa membuat/mengedit data jika schoolId sesuai
      allow create, update, delete: if isSignedIn() && (
        getUserData().role == 'superadmin' || 
        request.resource.data.schoolId == getUserData().schoolId ||
        resource.data.schoolId == getUserData().schoolId
      );
    }
  }
}