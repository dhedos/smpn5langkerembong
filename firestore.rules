rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    // Aturan untuk profil pengguna
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Aturan untuk Schools (Settings)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan untuk berita, fasilitas, galeri
    match /news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /facilities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /gallery/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Aturan fallback (diperlukan untuk inisialisasi awal)
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}