rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Aturan Profil Pengguna
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Aturan Global untuk Data Sekolah (Multi-Tenant)
    // Mengizinkan admin yang login untuk mengelola data
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Koleksi umum lainnya
    match /{collectionName}/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}