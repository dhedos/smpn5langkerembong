
{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Informasi umum sekolah dan pengaturan tampilan utama.",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string", "description": "Nama lengkap sekolah" },
        "schoolLogoUrl": { "type": "string", "description": "URL logo sekolah (PNG/SVG)" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImageUrl": { "type": "string", "description": "URL foto latar belakang utama" },
        "welcomeTitle": { "type": "string" },
        "welcomeMessage": { "type": "string" },
        "headmasterName": { "type": "string" },
        "headmasterTitle": { "type": "string" },
        "headmasterPhotoUrl": { "type": "string" },
        "whatsappNumber": { "type": "string", "description": "Nomor WhatsApp admin (format: 62812...)" },
        "address": { "type": "string", "description": "Alamat lengkap sekolah" },
        "phone": { "type": "string", "description": "Nomor telepon kantor" },
        "email": { "type": "string", "description": "Email resmi sekolah" },
        "history": { "type": "string", "description": "Teks sejarah sekolah" },
        "vision": { "type": "string", "description": "Teks visi sekolah" },
        "mission": { "type": "array", "items": { "type": "string" }, "description": "Daftar poin-poin misi" },
        "facebookUrl": { "type": "string", "description": "Link halaman Facebook" },
        "instagramUrl": { "type": "string", "description": "Link profil Instagram" },
        "twitterUrl": { "type": "string", "description": "Link profil Twitter/X" },
        "youtubeUrl": { "type": "string", "description": "Link channel YouTube" },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "ppdbYear": { "type": "string" },
        "ppdbIsActive": { "type": "boolean" },
        "ppdbMenuTitle": { "type": "string", "description": "Judul tombol menu SPMB" },
        "ppdbRequirements": { "type": "array", "items": { "type": "string" } },
        "ppdbQuotas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "News": {
      "title": "News",
      "description": "Berita dan pengumuman sekolah.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Facility": {
      "title": "Facility",
      "description": "Fasilitas sekolah.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published"] }
      }
    },
    "Gallery": {
      "title": "Gallery",
      "description": "Foto-foto kegiatan sekolah.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "AdminWhitelist": {
      "title": "Admin Whitelist",
      "description": "Daftar email yang diizinkan mengakses panel admin.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "superadmin"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/settings/general": {
      "schema": "SiteSettings",
      "description": "Singleton untuk pengaturan umum situs"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Koleksi berita sekolah"
    },
    "/facilities/{facilityId}": {
      "schema": "Facility",
      "description": "Koleksi fasilitas sekolah"
    },
    "/gallery/{photoId}": {
      "schema": "Gallery",
      "description": "Koleksi foto galeri sekolah"
    },
    "/admins/{email}": {
      "schema": "AdminWhitelist",
      "description": "Koleksi email admin yang terdaftar"
    }
  }
}
